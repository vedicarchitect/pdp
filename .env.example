# --- Core ---
APP_NAME=pdp
ENV=dev
LOG_LEVEL=INFO
GIT_SHA=local

# --- Mode gate ---
# LIVE=1 enables real broker routing; default false = paper-only
LIVE=false
BROKER=paper

# --- Database ---
# TimescaleDB-flavored Postgres
DATABASE_URL=postgresql+asyncpg://pdp:pdp@localhost:5432/pdp
DATABASE_SYNC_URL=postgresql+psycopg://pdp:pdp@localhost:5432/pdp

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Dhan (required only when BROKER=dhan or for live tick feed) ---
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
DHAN_SCRIPMASTER_URL=https://images.dhan.co/api-data/api-scrip-master-detailed.csv

# --- Paper engine ---
PAPER_SLIPPAGE_BPS=2
