# --- Core ---
APP_NAME=pdp
ENV=dev
LOG_LEVEL=INFO
GIT_SHA=local

# --- Mode gate ---
# LIVE=1 enables real broker routing; default false = paper-only
LIVE=false
BROKER=paper

# --- Database (PostgreSQL 16 — ACID ledger only: orders/trades/positions/instruments) ---
# Async app driver = +asyncpg; sync Alembic driver = +psycopg (psycopg 3)
DATABASE_URL=postgresql+asyncpg://pdp:pdp@localhost:5432/pdp
DATABASE_SYNC_URL=postgresql+psycopg://pdp:pdp@localhost:5432/pdp

# --- Redis (hot cache · pub/sub · streams) ---
REDIS_URL=redis://localhost:6379

# --- MongoDB (time-series warehouse: market_bars + option_chains + Greeks) ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=pdp
MONGO_CHAIN_TTL_DAYS=30

# --- Dhan (required only when BROKER=dhan or for live tick feed) ---
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
DHAN_SCRIPMASTER_URL=https://images.dhan.co/api-data/api-scrip-master-detailed.csv

# --- Paper engine ---
PAPER_SLIPPAGE_BPS=2

# --- Options analytics ---
OPTIONS_POLL_INTERVAL_SECONDS=30
OPTIONS_RISK_FREE_RATE=0.065
OPTIONS_UNDERLYINGS=["NIFTY","BANKNIFTY"]
OPTIONS_CHAIN_TTL_DAYS=7

# --- Portfolio engine ---
PORTFOLIO_MTM_INTERVAL_SECONDS=5
PORTFOLIO_EOD_SNAPSHOT=true

# --- CLI (pdp progress ...) — read via os.getenv, not Settings ---
DEFAULT_SYMBOL=NIFTY
